# GitHub — Personal Access Token (read:user scope)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Spotify — Developer App Credentials
# Create at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Spotify — OAuth Refresh Token
# Obtain via OAuth flow with scopes: user-read-currently-playing, user-read-recently-played
SPOTIFY_REFRESH_TOKEN=
